{
  "name": "devlife-simulator",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "web": "turbo run dev --filter=@devlife/web",
    "server": "turbo run dev --filter=@devlife/server",
    "telegram": "turbo run dev --filter=@devlife/telegram"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "npm@10.0.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
